{
  "name": "weza-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:website": "turbo run dev --filter=@weza/website",
    "dev:caisse": "turbo run dev --filter=@weza/caisse",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules .turbo"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  }
}
